# ---- LLM provider: gemini (free) | groq (free) | anthropic (paid) ----
LLM_PROVIDER=gemini

# Gemini (free tier — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free tier — https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (paid — https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Database: local SQLite by default; for deploy use a Supabase/Neon Postgres URL ----
DATABASE_URL=sqlite:///./certifizer.db

# ---- CORS: your frontend origin(s), comma-separated ----
CORS_ORIGINS=http://localhost:5173
